#!/usr/bin/env python3

from __future__ import annotations

import os
import sys
from pathlib import Path


def ensure_project_venv() -> None:
    """Automatically use the project venv when available."""
    script_path = Path(__file__).resolve()
    repo_root = script_path.parent
    venv_python = repo_root / ".venv" / "bin" / "python"

    if not venv_python.is_file():
        return

    if os.path.abspath(sys.executable) == os.path.abspath(venv_python):
        return

    os.execv(str(venv_python), [str(venv_python), *sys.argv])


ensure_project_venv()

from python.args import validate_staging_folder_name, validate_year_month
from python.meta import read_meta_entries, write_meta_entries
from python.pdf_merge_common import merge_pdfs
from python.transactions_paths import month_dir


def usage() -> str:
    return "Usage: merge_single_receipt_and_transaction_pdf <year> <month> <ordnername>"


def parse_args(argv: list[str]) -> tuple[int, int, str]:
    if len(argv) != 3:
        raise ValueError(usage())

    year, month = validate_year_month(argv[0], argv[1], example="2026 01")
    folder_name = validate_staging_folder_name(argv[2])
    return year, month, folder_name


def target_dir(repo_root: Path, year: int, month: int, folder_name: str) -> Path:
    return month_dir(repo_root, year, month) / folder_name


def require_single_billing_pdf(target: Path, transaction_filename: str | None) -> Path:
    pdf_paths = sorted(path for path in target.glob("*.pdf") if path.is_file())
    if transaction_filename:
        pdf_paths = [path for path in pdf_paths if path.name != transaction_filename]

    if len(pdf_paths) != 1:
        raise RuntimeError(f"Erwartet genau ein Rechnungs-PDF in {target}, gefunden: {len(pdf_paths)}")

    return pdf_paths[0]


def read_transaction_filename(meta_entry: dict[str, str]) -> str | None:
    transaction_filename = meta_entry.get("transaction_filename")
    if isinstance(transaction_filename, str) and transaction_filename.strip():
        return transaction_filename.strip()
    return None


def read_billing_filename(meta_entry: dict[str, str]) -> str | None:
    billing_filename = meta_entry.get("billing_filename")
    if isinstance(billing_filename, str) and billing_filename.strip():
        return billing_filename.strip()
    return None


def merged_filename(billing_filename: str) -> str:
    path = Path(billing_filename)
    return f"{path.stem}-beleg_und_buchung{path.suffix or '.pdf'}"


def main() -> None:
    try:
        year, month, folder_name = parse_args(sys.argv[1:])
    except ValueError as exc:
        print(exc)
        sys.exit(1)

    repo_root = Path(__file__).resolve().parent
    target = target_dir(repo_root, year, month, folder_name)

    if not target.is_dir():
        print(f"Ordner nicht gefunden: {target}")
        sys.exit(1)

    try:
        meta_entries = read_meta_entries(target)
        if len(meta_entries) > 1:
            raise RuntimeError(f"meta.json enthält mehr als einen Eintrag: {target / 'meta.json'}")
        meta_entry = dict(meta_entries[0]) if meta_entries else {}

        transaction_filename = read_transaction_filename(meta_entry)
        if not transaction_filename:
            raise RuntimeError("transaction_filename fehlt in meta.json. Bitte zuerst create_single_transaction_pdf ausführen.")

        transaction_pdf = target / transaction_filename
        if not transaction_pdf.is_file():
            raise RuntimeError(f"Kontobeleg-PDF nicht gefunden: {transaction_pdf}")

        billing_filename = read_billing_filename(meta_entry)
        if billing_filename:
            billing_pdf = target / billing_filename
            if not billing_pdf.is_file():
                raise RuntimeError(f"Rechnungs-PDF nicht gefunden: {billing_pdf}")
        else:
            billing_pdf = require_single_billing_pdf(target, transaction_filename)
        output_pdf = target / merged_filename(billing_pdf.name)
        merge_pdfs(billing_pdf, transaction_pdf, output_pdf)

        meta_entry["billing_filename"] = billing_pdf.name
        meta_entry["merged_filename"] = output_pdf.name
        write_meta_entries(target, [meta_entry])
    except RuntimeError as exc:
        print(f"Fehler: {exc}")
        sys.exit(1)

    print(output_pdf)
    print(target / 'meta.json')


if __name__ == "__main__":
    main()


