#!/usr/bin/env python3

from __future__ import annotations

import csv
import os
import sys
from collections import Counter
from pathlib import Path

from python.args import validate_year_month


def ensure_project_venv() -> None:
    """Automatically use the project venv when available."""
    script_path = Path(__file__).resolve()
    repo_root = script_path.parent
    venv_python = repo_root / ".venv" / "bin" / "python"

    if not venv_python.is_file():
        return

    if Path(sys.executable).resolve() == venv_python.resolve():
        return

    os.execv(str(venv_python), [str(venv_python), *sys.argv])


def usage() -> str:
    return "Usage: unprocessed_transactions <year> <month>"


def parse_year_month(argv: list[str]) -> tuple[int, int]:
    if len(argv) != 2:
        raise ValueError(usage())

    return validate_year_month(argv[0], argv[1], example="2026 01")


def month_dir(repo_root: Path, year: int, month: int) -> Path:
    return repo_root / "tmp" / "staging" / f"{year:04d}" / f"{month:02d}"


def source_csv_path(repo_root: Path, year: int, month: int) -> Path:
    return month_dir(repo_root, year, month) / "transactions.csv"


def read_csv_rows(path: Path) -> tuple[list[str], list[list[str]]]:
    with path.open("r", encoding="utf-8-sig", newline="") as handle:
        reader = csv.reader(handle, delimiter=";")
        try:
            header = next(reader)
        except StopIteration as exc:
            raise RuntimeError(f"Leere CSV-Datei: {path}") from exc

        rows = [row for row in reader if row and any(cell.strip() for cell in row)]

    return header, rows


def collect_processed_rows(month_path: Path) -> list[list[str]]:
    processed_rows: list[list[str]] = []

    for child in sorted(month_path.iterdir()):
        if not child.is_dir():
            continue

        vendor_csv = child / "transactions.csv"
        if not vendor_csv.is_file():
            continue

        _, rows = read_csv_rows(vendor_csv)
        processed_rows.extend(rows)

    return processed_rows


def subtract_rows(all_rows: list[list[str]], processed_rows: list[list[str]]) -> list[list[str]]:
    # Multiset subtraction keeps duplicate transactions stable.
    remaining = Counter(tuple(row) for row in all_rows)
    for row in processed_rows:
        row_key = tuple(row)
        if remaining[row_key] > 0:
            remaining[row_key] -= 1

    unprocessed: list[list[str]] = []
    for row in all_rows:
        row_key = tuple(row)
        if remaining[row_key] > 0:
            unprocessed.append(row)
            remaining[row_key] -= 1

    return unprocessed


def write_csv_to_stdout(header: list[str], rows: list[list[str]]) -> None:
    writer = csv.writer(sys.stdout, delimiter=";", lineterminator="\n")
    writer.writerow(header)
    writer.writerows(rows)


def main() -> None:
    ensure_project_venv()

    try:
        year, month = parse_year_month(sys.argv[1:])
    except ValueError as exc:
        print(exc)
        sys.exit(1)

    repo_root = Path(__file__).resolve().parent
    src_path = source_csv_path(repo_root, year, month)

    if not src_path.is_file():
        print(f"Quelldatei nicht gefunden: {src_path}")
        sys.exit(1)

    try:
        header, all_rows = read_csv_rows(src_path)
        processed_rows = collect_processed_rows(month_dir(repo_root, year, month))
        unprocessed_rows = subtract_rows(all_rows, processed_rows)
    except RuntimeError as exc:
        print(f"Fehler: {exc}")
        sys.exit(1)

    write_csv_to_stdout(header, unprocessed_rows)


if __name__ == "__main__":
    main()

