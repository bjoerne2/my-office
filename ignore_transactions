#!/usr/bin/env python3

from __future__ import annotations

import csv
import os
import sys
from dataclasses import dataclass
from pathlib import Path

from python.args import validate_year_month


@dataclass(frozen=True)
class IgnoreRule:
    name: str
    match_terms: tuple[str, ...]


IGNORE_RULES: tuple[IgnoreRule, ...] = (
    IgnoreRule(
        name="PayPal-Konto-Abbuchung",
        match_terms=("abbuchung vom paypal-konto",),
    ),
)


def ensure_project_venv() -> None:
    """Automatically use the project venv when available."""
    script_path = Path(__file__).resolve()
    repo_root = script_path.parent
    venv_python = repo_root / ".venv" / "bin" / "python"

    if not venv_python.is_file():
        return

    if Path(sys.executable).resolve() == venv_python.resolve():
        return

    os.execv(str(venv_python), [str(venv_python), *sys.argv])


def usage() -> str:
    return "Usage: ignore_transactions <year> <month>"


def parse_year_month(argv: list[str]) -> tuple[int, int]:
    if len(argv) != 2:
        raise ValueError(usage())

    return validate_year_month(argv[0], argv[1], example="2026 01")


def month_dir(repo_root: Path, year: int, month: int) -> Path:
    return repo_root / "tmp" / "staging" / f"{year:04d}" / f"{month:02d}"


def source_csv_path(repo_root: Path, year: int, month: int) -> Path:
    return month_dir(repo_root, year, month) / "transactions.csv"


def ignored_csv_path(repo_root: Path, year: int, month: int) -> Path:
    return month_dir(repo_root, year, month) / "Ignored" / "transactions.csv"


def read_csv_rows(path: Path) -> tuple[list[str], list[list[str]]]:
    with path.open("r", encoding="utf-8-sig", newline="") as handle:
        reader = csv.reader(handle, delimiter=";")
        try:
            header = next(reader)
        except StopIteration as exc:
            raise RuntimeError(f"Leere CSV-Datei: {path}") from exc

        rows = [row for row in reader if row and any(cell.strip() for cell in row)]

    return header, rows


def row_matches_ignore_rule(row: list[str]) -> bool:
    haystack = " ".join(cell.strip().lower() for cell in row)
    return any(term in haystack for rule in IGNORE_RULES for term in rule.match_terms)


def select_ignored_rows(rows: list[list[str]]) -> list[list[str]]:
    return [row for row in rows if row_matches_ignore_rule(row)]


def write_csv(path: Path, header: list[str], rows: list[list[str]]) -> Path:
    path.parent.mkdir(parents=True, exist_ok=True)

    with path.open("w", encoding="utf-8", newline="") as handle:
        writer = csv.writer(handle, delimiter=";", lineterminator="\n")
        writer.writerow(header)
        writer.writerows(rows)

    return path


def main() -> None:
    ensure_project_venv()

    try:
        year, month = parse_year_month(sys.argv[1:])
    except ValueError as exc:
        print(exc)
        sys.exit(1)

    repo_root = Path(__file__).resolve().parent
    src_path = source_csv_path(repo_root, year, month)
    dst_path = ignored_csv_path(repo_root, year, month)

    if not src_path.is_file():
        print(f"Quelldatei nicht gefunden: {src_path}")
        sys.exit(1)

    try:
        header, all_rows = read_csv_rows(src_path)
        ignored_rows = select_ignored_rows(all_rows)
        output_path = write_csv(dst_path, header, ignored_rows)
    except RuntimeError as exc:
        print(f"Fehler: {exc}")
        sys.exit(1)

    print(output_path)


if __name__ == "__main__":
    main()

