#!/usr/bin/env python3

from __future__ import annotations

import os
import sys
from decimal import Decimal, InvalidOperation
from pathlib import Path


def ensure_project_venv() -> None:
    """Automatically use the project venv when available."""
    script_path = Path(__file__).resolve()
    repo_root = script_path.parent
    venv_python = repo_root / ".venv" / "bin" / "python"

    if not venv_python.is_file():
        return

    if os.path.abspath(sys.executable) == os.path.abspath(venv_python):
        return

    os.execv(str(venv_python), [str(venv_python), *sys.argv])


ensure_project_venv()

from python.args import validate_staging_folder_name, validate_year_month
from python.meta import read_meta_entries, write_meta_entries
from python.transaction_pdf_common import write_cash_payment_pdf
from python.transactions_paths import month_dir


def usage() -> str:
    return "Usage: create_cash_payment_pdf <year> <month> <ordnername> <amount>"


def parse_amount(value: str) -> Decimal:
    normalized = value.strip()
    if not normalized:
        raise ValueError("Betrag darf nicht leer sein")

    if "." in normalized and "," in normalized:
        normalized = normalized.replace(".", "").replace(",", ".")
    elif "," in normalized:
        normalized = normalized.replace(",", ".")

    try:
        amount = abs(Decimal(normalized))
    except InvalidOperation as exc:
        raise ValueError(f"Ungültiger Betrag: {value}") from exc

    if amount == 0:
        raise ValueError("Betrag muss ungleich 0 sein")

    return amount


def parse_args(argv: list[str]) -> tuple[int, int, str, Decimal]:
    if len(argv) != 4:
        raise ValueError(usage())

    year, month = validate_year_month(argv[0], argv[1], example="2026 01")
    folder_name = validate_staging_folder_name(argv[2])
    amount = parse_amount(argv[3])
    return year, month, folder_name, amount


def target_dir(repo_root: Path, year: int, month: int, folder_name: str) -> Path:
    return month_dir(repo_root, year, month) / folder_name


def output_pdf_path(target: Path, year: int, month: int) -> Path:
    return target / f"transaction-barzahlung-{year:04d}-{month:02d}.pdf"


def serialize_amount(amount: Decimal) -> str:
    return f"{amount.quantize(Decimal('0.01')):.2f}"


def read_billing_filename(meta_entry: dict[str, str]) -> str | None:
    billing_filename = meta_entry.get("billing_filename")
    if isinstance(billing_filename, str) and billing_filename.strip():
        return billing_filename.strip()
    return None


def read_description(meta_entry: dict[str, str]) -> str | None:
    description = meta_entry.get("description")
    if isinstance(description, str) and description.strip():
        return description.strip()
    return None


def main() -> None:
    try:
        year, month, folder_name, amount = parse_args(sys.argv[1:])
    except ValueError as exc:
        print(exc)
        sys.exit(1)

    repo_root = Path(__file__).resolve().parent
    target = target_dir(repo_root, year, month, folder_name)
    pdf_path = output_pdf_path(target, year, month)

    if not target.is_dir():
        print(f"Ordner nicht gefunden: {target}")
        sys.exit(1)

    try:
        meta_entries = read_meta_entries(target)
        if len(meta_entries) > 1:
            raise RuntimeError(f"meta.json enthält mehr als einen Eintrag: {target / 'meta.json'}")
        meta_entry = dict(meta_entries[0]) if meta_entries else {}
        meta_entry["type"] = meta_entry.get("type") or "incoming"
        billing_filename = read_billing_filename(meta_entry)
        description = read_description(meta_entry)
        write_cash_payment_pdf(
            pdf_path,
            amount,
            billing_filename=billing_filename,
            description=description,
            month_label=f"{month:02d}/{year:04d}",
        )
        meta_entry["transaction_filename"] = pdf_path.name
        meta_entry["payment_method"] = "cash"
        meta_entry["cash_amount"] = serialize_amount(amount)
        write_meta_entries(target, [meta_entry])
    except RuntimeError as exc:
        print(f"Fehler: {exc}")
        sys.exit(1)

    print(pdf_path)
    print(target / "meta.json")


if __name__ == "__main__":
    main()
