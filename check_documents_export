#!/usr/bin/env python3

from __future__ import annotations

import json
import os
import sys
from pathlib import Path
from typing import Any

from python.args import validate_year_month
from python.vendors import list_expected_documents_export_dirs

CONFIG_FILENAME = ".my-office.local.json"
CONFIG_DIR_KEY = "documents_export_dir"
DOCUMENT_INDENT = 32


def ensure_project_venv() -> None:
    """Automatically use the project venv when available."""
    script_path = Path(__file__).resolve()
    repo_root = script_path.parent
    venv_python = repo_root / ".venv" / "bin" / "python"

    if not venv_python.is_file():
        return

    if os.path.abspath(sys.executable) == os.path.abspath(venv_python):
        return

    os.execv(str(venv_python), [str(venv_python), *sys.argv])


ensure_project_venv()


def usage() -> str:
    return "Usage: check_documents_export <year> <month>"


def parse_args(argv: list[str]) -> tuple[int, int]:
    if len(argv) != 2:
        raise ValueError(usage())

    return validate_year_month(argv[0], argv[1], example="2026 01")


def repo_root() -> Path:
    return Path(__file__).resolve().parent


def config_path(root: Path) -> Path:
    return root / CONFIG_FILENAME


def load_config(path: Path) -> dict[str, Any]:
    if not path.is_file():
        raise RuntimeError(f"Konfigurationsdatei nicht gefunden: {path}")

    try:
        with path.open("r", encoding="utf-8") as handle:
            data = json.load(handle)
    except (OSError, json.JSONDecodeError) as exc:
        raise RuntimeError(f"Konfigurationsdatei ungültig: {path}") from exc

    if not isinstance(data, dict):
        raise RuntimeError(f"Konfigurationsdatei hat ungültiges Format: {path}")

    return data


def export_target_dir(config: dict[str, Any]) -> Path:
    value = config.get(CONFIG_DIR_KEY)
    if not isinstance(value, str) or not value.strip():
        raise RuntimeError(f"Konfigurationsschlüssel fehlt oder ist leer: {CONFIG_DIR_KEY}")

    return Path(value).expanduser()


def month_dir(base_dir: Path, year: int, month: int) -> Path:
    return base_dir / f"{year:04d}" / f"{month:02d}"


def merged_documents_in_dir(directory: Path) -> list[str]:
    meta_path = directory / "meta.json"
    if not meta_path.is_file():
        return []

    try:
        with meta_path.open("r", encoding="utf-8") as handle:
            data = json.load(handle)
    except (OSError, json.JSONDecodeError) as exc:
        raise RuntimeError(f"Ungültige meta.json: {meta_path}") from exc

    if not isinstance(data, list):
        raise RuntimeError(f"meta.json hat kein Listenformat: {meta_path}")

    merged_filenames: list[str] = []
    seen: set[str] = set()
    for entry in data:
        if not isinstance(entry, dict):
            raise RuntimeError(f"meta.json enthält ungültigen Eintrag: {meta_path}")

        merged_filename = entry.get("merged_filename")
        if not isinstance(merged_filename, str) or not merged_filename.strip():
            continue

        normalized = merged_filename.strip()
        if normalized in seen:
            continue

        seen.add(normalized)
        merged_filenames.append(normalized)

    return merged_filenames


def main() -> None:
    try:
        year, month = parse_args(sys.argv[1:])
    except ValueError as exc:
        print(exc)
        sys.exit(1)

    root = repo_root()

    try:
        config = load_config(config_path(root))
        base_dir = export_target_dir(config)
    except RuntimeError as exc:
        print(f"Fehler: {exc}")
        sys.exit(1)

    expected = list(list_expected_documents_export_dirs())

    target_month_dir = month_dir(base_dir, year, month)
    if not target_month_dir.is_dir():
        print(f"Fehler: Zielverzeichnis nicht gefunden: {target_month_dir}")
        sys.exit(1)

    found_dirs = sorted(child for child in target_month_dir.iterdir() if child.is_dir())
    found_names = {child.name for child in found_dirs}

    for child in found_dirs:
        marker = "✅" if child.name in expected else "➕"
        print(f"{marker} {child.name}")
        for document_name in merged_documents_in_dir(child):
            print(f"{' ' * DOCUMENT_INDENT}{document_name}")
        print()

    missing = [name for name in expected if name not in found_names]
    for name in missing:
        print(f"{name} ❌")


if __name__ == "__main__":
    main()

