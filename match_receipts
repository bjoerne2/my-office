def collect_candidates(pdf_dir: Path, vendor: VendorRule) -> list[PdfCandidate]:
    if vendor.slug == "aws":
        return collect_aws_candidates(pdf_dir)
    if vendor.slug == "domainfactory":
        return collect_domainfactory_candidates(pdf_dir)
    if vendor.slug == "dkb":
        return collect_static_candidates(pdf_dir, "Kontodetails*.pdf", "DKB")
    if vendor.slug == "google":
        return collect_google_candidates(pdf_dir)
    if vendor.slug == "hosting":
        return collect_hosting_candidates(pdf_dir)
    if vendor.slug == "hp":
        return collect_hp_candidates(pdf_dir)
    if vendor.slug == "openai":
        return collect_openai_candidates(pdf_dir)
    if vendor.slug == "telekom":
        return collect_static_candidates(pdf_dir, "Vertragsdetails*.pdf", "Telekom")

    return collect_default_candidates(pdf_dir, vendor)


def choose_best_candidate_by_date(transaction_date: date, candidates: list[PdfCandidate]) -> PdfCandidate:
    monthly_candidates = [
        candidate
        for candidate in candidates
        if candidate.receipt_date.year == transaction_date.year and candidate.receipt_date.month == transaction_date.month
    ]

    if not monthly_candidates:
        raise RuntimeError(
            f"Kein PDF für {transaction_date.strftime('%Y-%m')} gefunden"
        )

    return min(
        monthly_candidates,
        key=lambda candidate: abs((candidate.receipt_date - transaction_date).days),
    )


def aws_transaction_kind(record: TransactionRecord) -> str | None:
    normalized_issuer = record.issuer_name.strip().lower()
    if "amazon payments europe" in normalized_issuer:
        return "marketplace"
    if "amazon web services emea" in normalized_issuer:
        return "service"
    return None


def choose_best_aws_candidate(record: TransactionRecord, candidates: list[PdfCandidate]) -> PdfCandidate:
    expected_kind = aws_transaction_kind(record)
    matching_candidates = [candidate for candidate in candidates if candidate.total_amount == record.amount]

    if expected_kind is not None:
        matching_candidates = [candidate for candidate in matching_candidates if candidate.kind == expected_kind]

    if not matching_candidates:
        raise RuntimeError(
            "Kein AWS-PDF für "
            f"{record.booking_date.strftime('%Y-%m-%d')} "
            f"mit Betrag {record.amount} und Rechnungssteller {record.issuer_name} gefunden"
        )

    return min(
        matching_candidates,
        key=lambda candidate: abs((candidate.receipt_date - record.booking_date).days),
    )


