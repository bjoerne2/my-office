DATE_PATTERN = re.compile(r"(\d{4})-(\d{2})-(\d{2})")
AWS_INVOICE_DATE_PATTERN = re.compile(r"(?:VAT\s+)?Invoice Date:\s*([A-Za-z]+\s+\d{1,2},\s+\d{4})")
AWS_TOTAL_AMOUNT_PATTERN = re.compile(r"TOTAL AMOUNT\s+EUR\s+([0-9][0-9.,]*)")
HP_BILLING_DATE_PATTERN = re.compile(r"Abrechnungsdatum:\s*([0-9]{2}\.[0-9]{2}\.[0-9]{2})")
HP_TOTAL_AMOUNT_PATTERN = re.compile(r"Gesamtsumme:\s*([0-9][0-9.,]*)\s*€")
GOOGLE_TOTAL_AMOUNT_PATTERN = re.compile(r"Gesamtsumme in EUR\s*([0-9][0-9.,]*)\s*€", re.IGNORECASE)
OPENAI_INVOICE_DATE_PATTERN = re.compile(r"Date of issue\s+([A-Za-z]+\s+\d{1,2},\s+\d{4})")
OPENAI_AMOUNT_DUE_PATTERN = re.compile(r"Amount due\s+€\s*([0-9][0-9.,]*)")
GERMAN_DATE_PATTERN = re.compile(r"([0-9]{1,2})\.\s*([A-Za-zÄÖÜäöü]{3,10})\.?\s*([0-9]{4})")
HOSTING_PDF_NUMBER_PATTERN = re.compile(r"RE-(\d+)")
HOSTING_RENR_PATTERN = re.compile(r"Renr\s+(\d+)")
DOMAINFACTORY_PDF_NUMBER_PATTERN = re.compile(r"_RE(\d+)\.pdf$", re.IGNORECASE)
DOMAINFACTORY_RENR_PATTERN = re.compile(r"Rg\.\s*(\d+)\b", re.IGNORECASE)
DATE_FIELD_LABELS = ("Buchungstag", "Datum")
AMOUNT_FIELD_LABELS = ("Betrag",)
ISSUER_FIELD_LABELS = ("Name", "Auftraggeber/Empfänger")

GERMAN_MONTHS = {
    "jan": 1,
    "januar": 1,
    "feb": 2,
    "februar": 2,
    "mae": 3,
    "maerz": 3,
    "mrz": 3,
    "marz": 3,
    "apr": 4,
    "april": 4,
    "mai": 5,
    "jun": 6,
    "juni": 6,
    "jul": 7,
    "juli": 7,
    "aug": 8,
    "august": 8,
    "sep": 9,
    "sept": 9,
    "september": 9,
    "okt": 10,
    "oktober": 10,
    "nov": 11,
    "november": 11,
    "dez": 12,
    "dezember": 12,
}


@dataclass(frozen=True)
class TransactionRecord:
    booking_date: date
    issuer_name: str
    amount: Decimal
    invoice_ref: str | None = None


@dataclass(frozen=True)
class PdfCandidate:
    path: Path
    receipt_date: date | None = None
    total_amount: Decimal | None = None
    kind: str | None = None
    invoice_ref: str | None = None


def ensure_project_venv() -> None:
    """Automatically use the project venv when available."""
    script_path = Path(__file__).resolve()
    repo_root = script_path.parent
    venv_python = repo_root / ".venv" / "bin" / "python"

    if not venv_python.is_file():
        return

    if os.path.abspath(sys.executable) == os.path.abspath(venv_python):
        return

    os.execv(str(venv_python), [str(venv_python), *sys.argv])


def usage() -> str:
    return "Usage: match_receipts <year> <month> <rechnungssteller>"


def parse_args(argv: list[str]) -> tuple[int, int, VendorRule]:
    if len(argv) != 3:
        raise ValueError(usage())

    year, month = validate_year_month(argv[0], argv[1], example="2026 01")
    vendor = validate_vendor(argv[2], get_vendor_rule)
    return year, month, vendor


def transactions_csv_path(repo_root: Path, year: int, month: int, vendor: VendorRule) -> Path:
    return repo_root / "tmp" / "staging" / f"{year:04d}" / f"{month:02d}" / vendor.directory_name / "transactions.csv"


def staging_dir(repo_root: Path, year: int, month: int, vendor: VendorRule) -> Path:
    return repo_root / "tmp" / "staging" / f"{year:04d}" / f"{month:02d}" / vendor.directory_name


def app_data_dir(repo_root: Path, vendor: VendorRule) -> Path:
    if vendor.slug in {"dkb", "openai", "telekom"}:
        return repo_root / "tmp" / "download" / vendor.directory_name
    elif vendor.slug == "hp":
        return repo_root / "tmp" / "download" / "HP Instant Ink"

    return repo_root / "tmp" / "app_scripts_data" / vendor.directory_name


def parse_ddmmyyyy(value: str) -> date:
    return datetime.strptime(value.strip(), "%d.%m.%Y").date()


def parse_invoice_date(value: str) -> date:
    return datetime.strptime(value.strip(), "%B %d, %Y").date()


def parse_ddmmyy(value: str) -> date:
    return datetime.strptime(value.strip(), "%d.%m.%y").date()


def parse_german_date(day: str, month_token: str, year: str) -> date:
    normalized_month = month_token.strip().lower().replace(".", "")
    normalized_month = normalized_month.replace("ä", "ae").replace("ö", "oe").replace("ü", "ue")
    month = GERMAN_MONTHS.get(normalized_month)
    if month is None:
        raise RuntimeError(f"Unbekannter Monatsname: {month_token}")

    return date(int(year), month, int(day))


def parse_eur_amount(value: str) -> Decimal:
    normalized = value.strip()
    if "." in normalized and "," in normalized:
        normalized = normalized.replace(".", "").replace(",", ".")
    elif "," in normalized:
        normalized = normalized.replace(",", ".")
    try:
        return abs(Decimal(normalized))
    except InvalidOperation as exc:
        raise RuntimeError(f"Ungültiger Betrag: {value}") from exc


def normalize_nfc(value: str) -> str:
    return unicodedata.normalize("NFC", value)


def parse_pdf_date(filename: str) -> date | None:
    match = DATE_PATTERN.search(filename)
    if not match:
        return None

    year, month, day = (int(part) for part in match.groups())
    return date(year, month, day)


def find_column_index(header: list[str], supported_labels: tuple[str, ...]) -> int:
    for label in supported_labels:
        try:
            return header.index(label)
        except ValueError:
            continue

    supported = ", ".join(supported_labels)
    raise RuntimeError(f"CSV-Spalte nicht gefunden ({supported}) in {header}")


def extract_invoice_ref_from_purpose(value: str, vendor: VendorRule) -> str | None:
    if vendor.slug == "hosting":
        patterns = (HOSTING_RENR_PATTERN,)
    elif vendor.slug == "domainfactory":
        patterns = (DOMAINFACTORY_RENR_PATTERN,)
    else:
        patterns = ()

    for pattern in patterns:
        match = pattern.search(value)
        if match:
            return match.group(1)

    return None


def read_transaction_records(csv_path: Path, vendor: VendorRule) -> list[TransactionRecord]:
    with csv_path.open("r", encoding="utf-8-sig", newline="") as handle:
        reader = csv.reader(handle, delimiter=";")

        try:
            header = next(reader)
        except StopIteration as exc:
            raise RuntimeError(f"Leere CSV-Datei: {csv_path}") from exc

        booking_date_index = find_column_index(header, DATE_FIELD_LABELS)
        amount_index = find_column_index(header, AMOUNT_FIELD_LABELS)
        issuer_index = find_column_index(header, ISSUER_FIELD_LABELS)

        zweck_index: int | None = None
        if vendor.slug in {"hosting", "domainfactory"}:
            try:
                zweck_index = find_column_index(header, ("Verwendungszweck",))
            except RuntimeError:
                pass

        records: list[TransactionRecord] = []
        for row in reader:
            if not row or not any(cell.strip() for cell in row):
                continue
            if max(booking_date_index, amount_index, issuer_index) >= len(row):
                raise RuntimeError(f"CSV-Zeile unvollständig: {row}")

            invoice_ref: str | None = None
            if zweck_index is not None and zweck_index < len(row):
                invoice_ref = extract_invoice_ref_from_purpose(row[zweck_index], vendor)

            records.append(
                TransactionRecord(
                    booking_date=parse_ddmmyyyy(row[booking_date_index]),
                    issuer_name=row[issuer_index].strip(),
                    amount=parse_eur_amount(row[amount_index]),
                    invoice_ref=invoice_ref,
                )
            )

    if not records:
        raise RuntimeError(f"Keine Transaktionen in {csv_path} gefunden")

    return records


def collect_default_candidates(pdf_dir: Path, vendor: VendorRule) -> list[PdfCandidate]:
    candidates: list[PdfCandidate] = []

    for path in sorted(pdf_dir.glob("*.pdf")):
        if not path.name.lower().startswith(vendor.pdf_prefix.lower()):
            continue

        receipt_date = parse_pdf_date(path.name)
        if receipt_date is None:
            continue

        candidates.append(PdfCandidate(path=path, receipt_date=receipt_date))

    if not candidates:
        raise RuntimeError(f"Keine PDF-Kandidaten für {vendor.directory_name} in {pdf_dir} gefunden")

    return candidates


def collect_static_candidates(pdf_dir: Path, pattern: str, label: str) -> list[PdfCandidate]:
    paths = sorted(pdf_dir.glob(pattern))
    if not paths:
        raise RuntimeError(f"Keine statische {label}-PDF in {pdf_dir} gefunden")

    return [PdfCandidate(path=paths[0])]


def extract_pdf_text(path: Path) -> str:
    from pypdf import PdfReader

    return " ".join((page.extract_text() or "") for page in PdfReader(str(path)).pages[:2])


def extract_aws_candidate(path: Path) -> PdfCandidate | None:
    text = extract_pdf_text(path)
    normalized_text = " ".join(text.split())

    amount_match = AWS_TOTAL_AMOUNT_PATTERN.search(normalized_text)
    date_match = AWS_INVOICE_DATE_PATTERN.search(normalized_text)
    if amount_match is None or date_match is None:
        return None

    kind = "marketplace" if path.name.upper().startswith("EUMP") else "service"
    return PdfCandidate(
        path=path,
        receipt_date=parse_invoice_date(date_match.group(1)),
        total_amount=parse_eur_amount(amount_match.group(1)),
        kind=kind,
    )


def collect_aws_candidates(pdf_dir: Path) -> list[PdfCandidate]:
    candidates: list[PdfCandidate] = []

    for path in sorted(pdf_dir.glob("*.pdf")):
        candidate = extract_aws_candidate(path)
        if candidate is not None:
            candidates.append(candidate)

    if not candidates:
        raise RuntimeError(f"Keine AWS-PDF-Kandidaten in {pdf_dir} gefunden")

    return candidates


def extract_google_candidate(path: Path) -> PdfCandidate | None:
    text = extract_pdf_text(path)
    normalized_text = " ".join(text.split())

    amount_match = GOOGLE_TOTAL_AMOUNT_PATTERN.search(normalized_text)
    if amount_match is None:
        return None

    date_matches = GERMAN_DATE_PATTERN.findall(normalized_text)
    if not date_matches:
        return None

    parsed_dates = [parse_german_date(day, month, year) for day, month, year in date_matches]
    receipt_date = max(parsed_dates)

    return PdfCandidate(
        path=path,
        receipt_date=receipt_date,
        total_amount=parse_eur_amount(amount_match.group(1)),
    )


def collect_google_candidates(pdf_dir: Path) -> list[PdfCandidate]:
    candidates: list[PdfCandidate] = []

    for path in sorted(pdf_dir.glob("*.pdf")):
        candidate = extract_google_candidate(path)
        if candidate is not None:
            candidates.append(candidate)

    if not candidates:
        raise RuntimeError(f"Keine Google-PDF-Kandidaten in {pdf_dir} gefunden")

    return candidates


def extract_openai_candidate(path: Path) -> PdfCandidate | None:
    text = extract_pdf_text(path)
