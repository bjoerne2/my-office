def collect_hosting_candidates(pdf_dir: Path) -> list[PdfCandidate]:
    candidates: list[PdfCandidate] = []

    for path in sorted(pdf_dir.glob("*.pdf")):
        m = HOSTING_PDF_NUMBER_PATTERN.search(path.name)
        if not m:
            continue

        invoice_ref = m.group(1)
        receipt_date: date | None = None

        try:
            text = extract_pdf_text(path)
            date_matches = re.findall(r"(\d{2})\.(\d{2})\.(\d{4})", text)
            if date_matches:
                day, mon, yr = date_matches[0]
                receipt_date = date(int(yr), int(mon), int(day))
        except Exception:
            pass

        candidates.append(PdfCandidate(path=path, receipt_date=receipt_date, invoice_ref=invoice_ref))

    if not candidates:
        raise RuntimeError(f"Keine hosting.de-PDF-Kandidaten in {pdf_dir} gefunden")

    return candidates


def collect_domainfactory_candidates(pdf_dir: Path) -> list[PdfCandidate]:
    candidates: list[PdfCandidate] = []

    for path in sorted(pdf_dir.glob("*.pdf")):
        m = DOMAINFACTORY_PDF_NUMBER_PATTERN.search(path.name)
        if not m:
            continue

        invoice_ref = m.group(1)
        receipt_date = parse_pdf_date(path.name)
        candidates.append(PdfCandidate(path=path, receipt_date=receipt_date, invoice_ref=invoice_ref))

    if not candidates:
        raise RuntimeError(f"Keine DomainFactory-PDF-Kandidaten in {pdf_dir} gefunden")

