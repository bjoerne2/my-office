def extract_hp_candidate(path: Path) -> PdfCandidate | None:
    text = extract_pdf_text(path)
    normalized_text = " ".join(text.split())

    amount_match = HP_TOTAL_AMOUNT_PATTERN.search(normalized_text)
    billing_date_match = HP_BILLING_DATE_PATTERN.search(normalized_text)
    if amount_match is None or billing_date_match is None:
        return None

    return PdfCandidate(
        path=path,
        receipt_date=parse_ddmmyy(billing_date_match.group(1)),
        total_amount=parse_eur_amount(amount_match.group(1)),
    )


def collect_hp_candidates(pdf_dir: Path) -> list[PdfCandidate]:
    candidates: list[PdfCandidate] = []

