    amount_match = OPENAI_AMOUNT_DUE_PATTERN.search(normalized_text)
    date_match = OPENAI_INVOICE_DATE_PATTERN.search(normalized_text)
    if amount_match is None or date_match is None:
        return None

    return PdfCandidate(
        path=path,
        receipt_date=parse_invoice_date(date_match.group(1)),
