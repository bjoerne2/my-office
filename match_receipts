def choose_best_hosting_candidate(record: TransactionRecord, candidates: list[PdfCandidate]) -> PdfCandidate:
    # Primär: Matching per Rechnungsnummer
    if record.invoice_ref:
        matching = [c for c in candidates if c.invoice_ref == record.invoice_ref]
        if matching:
            return matching[0]

    # Fallback: Monatsgenaues Datums-Matching (z.B. PayPal-Transaktionen ohne Renr)
    monthly = [
        c for c in candidates
        if c.receipt_date is not None
        and c.receipt_date.year == record.booking_date.year
        and c.receipt_date.month == record.booking_date.month
    ]
    if monthly:
        return min(monthly, key=lambda c: abs((c.receipt_date - record.booking_date).days))

    raise RuntimeError(
        f"Kein hosting.de-PDF für Rechnungsnummer {record.invoice_ref or '(unbekannt)'} "
        f"vom {record.booking_date.strftime('%Y-%m-%d')} gefunden"
    )


def choose_best_domainfactory_candidate(record: TransactionRecord, candidates: list[PdfCandidate]) -> PdfCandidate:
    if record.invoice_ref:
        matching = [candidate for candidate in candidates if candidate.invoice_ref == record.invoice_ref]
        if matching:
            return matching[0]

    monthly = [
        candidate
        for candidate in candidates
        if candidate.receipt_date is not None
        and candidate.receipt_date.year == record.booking_date.year
        and candidate.receipt_date.month == record.booking_date.month
    ]
    if monthly:
        return min(monthly, key=lambda candidate: abs((candidate.receipt_date - record.booking_date).days))

    raise RuntimeError(
        f"Kein DomainFactory-PDF für Rechnungsnummer {record.invoice_ref or '(unbekannt)'} "
        f"vom {record.booking_date.strftime('%Y-%m-%d')} gefunden"
    )


def match_pdfs_to_transactions(vendor: VendorRule, records: list[TransactionRecord], candidates: list[PdfCandidate]) -> list[Path]:
    if vendor.slug == "aws":
        remaining_candidates = list(candidates)
        matched_paths: list[Path] = []
        for record in records:
            candidate = choose_best_aws_candidate(record, remaining_candidates)
            remaining_candidates.remove(candidate)
            matched_paths.append(candidate.path)
        return matched_paths

    if vendor.slug == "hp":
        remaining_candidates = list(candidates)
        matched_paths: list[Path] = []
        for record in records:
            candidate = choose_best_hp_candidate(record, remaining_candidates)
            remaining_candidates.remove(candidate)
            matched_paths.append(candidate.path)
        return matched_paths

    if vendor.slug in {"dkb", "telekom"}:
        return [candidates[0].path for _ in records]

    if vendor.slug == "google":
        remaining_candidates = list(candidates)
        matched_paths: list[Path] = []
        for record in records:
            candidate = choose_best_google_candidate(record, remaining_candidates)
            remaining_candidates.remove(candidate)
            matched_paths.append(candidate.path)
        return matched_paths

    if vendor.slug == "openai":
        remaining_candidates = list(candidates)
        matched_paths: list[Path] = []
        for record in records:
            candidate = choose_best_openai_candidate(record, remaining_candidates)
            remaining_candidates.remove(candidate)
            matched_paths.append(candidate.path)
        return matched_paths

    if vendor.slug == "hosting":
        remaining_candidates = list(candidates)
        matched_paths = []
        for record in records:
            candidate = choose_best_hosting_candidate(record, remaining_candidates)
            remaining_candidates.remove(candidate)
            matched_paths.append(candidate.path)
        return matched_paths

    if vendor.slug == "domainfactory":
        remaining_candidates = list(candidates)
        matched_paths = []
        for record in records:
            candidate = choose_best_domainfactory_candidate(record, remaining_candidates)
            remaining_candidates.remove(candidate)
            matched_paths.append(candidate.path)
        return matched_paths

    return [choose_best_candidate_by_date(record.booking_date, candidates).path for record in records]


def copy_unique_pdfs(target_dir: Path, pdfs: list[Path]) -> dict[Path, Path]:
    target_dir.mkdir(parents=True, exist_ok=True)

    copied_paths: dict[Path, Path] = {}
    for source_path in sorted(set(pdfs)):
        destination_path = target_dir / normalize_nfc(source_path.name)
        shutil.copy2(source_path, destination_path)
        copied_paths[source_path] = destination_path

    return copied_paths


def main() -> None:
    ensure_project_venv()

    try:
        year, month, vendor = parse_args(sys.argv[1:])
    except ValueError as exc:
        print(exc)
        sys.exit(1)

    repo_root = Path(__file__).resolve().parent
    csv_path = transactions_csv_path(repo_root, year, month, vendor)
    pdf_dir = app_data_dir(repo_root, vendor)
    target_dir = staging_dir(repo_root, year, month, vendor)

    if not csv_path.is_file():
        print(f"Transaktionsdatei nicht gefunden: {csv_path}")
        sys.exit(1)

    if not pdf_dir.is_dir():
        print(f"PDF-Quellordner nicht gefunden: {pdf_dir}")
        sys.exit(1)

    try:
        transaction_records = read_transaction_records(csv_path, vendor)
        candidates = collect_candidates(pdf_dir, vendor)
        matched_pdfs = match_pdfs_to_transactions(vendor, transaction_records, candidates)
        copied_paths = copy_unique_pdfs(target_dir, matched_pdfs)
        meta_entries = [
            {"billing_filename": copied_paths[matched_pdf].name, "type": "incoming"}
            for matched_pdf in matched_pdfs
        ]
        meta_path = write_meta_entries(target_dir, meta_entries)
    except RuntimeError as exc:
        print(f"Fehler: {exc}")
        sys.exit(1)

    for path in copied_paths.values():
        print(path)
    print(meta_path)


if __name__ == "__main__":
    main()
