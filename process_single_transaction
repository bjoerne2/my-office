#!/usr/bin/env python3

from __future__ import annotations

import os
import sys
from pathlib import Path


def main() -> None:
    repo_root = Path(__file__).resolve().parent
    target = repo_root / "process_single_receipt"
    os.execv(str(target), [str(target), *sys.argv[1:]])


if __name__ == "__main__":
    main()

