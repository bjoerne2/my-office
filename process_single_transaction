#!/usr/bin/env python3

from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path


def ensure_project_venv() -> None:
    """Automatically use the project venv when available."""
    script_path = Path(__file__).resolve()
    repo_root = script_path.parent
    venv_python = repo_root / ".venv" / "bin" / "python"

    if not venv_python.is_file():
        return

    if os.path.abspath(sys.executable) == os.path.abspath(venv_python):
        return

    os.execv(str(venv_python), [str(venv_python), *sys.argv])


ensure_project_venv()


def usage() -> str:
    return "Usage: process_single_transaction <ordnername>"


def parse_args(argv: list[str]) -> str:
    if len(argv) != 1:
        raise ValueError(usage())

    folder_name = argv[0].strip()
    if not folder_name:
        raise ValueError("Ordnername darf nicht leer sein")

    return folder_name


def run_step(repo_root: Path, script_name: str, args: list[str]) -> None:
    script_path = repo_root / script_name
    if not script_path.is_file():
        raise RuntimeError(f"Skript nicht gefunden: {script_path}")

    command = [str(script_path), *args]
    result = subprocess.run(command, capture_output=True, text=True, check=False)

    if result.stdout:
        print(result.stdout.strip())

    if result.returncode != 0:
        error_output = result.stderr.strip() if result.stderr else ""
        details = error_output or result.stdout.strip() or f"{script_name} fehlgeschlagen"
        raise RuntimeError(details)


def main() -> None:
    try:
        folder_name = parse_args(sys.argv[1:])
    except ValueError as exc:
        print(exc)
        sys.exit(1)

    repo_root = Path(__file__).resolve().parent
    steps = (
        "detect_single_receipt_pdf",
        "create_single_transaction_pdf",
        "merge_single_receipt_and_transaction_pdf",
    )

    try:
        for script_name in steps:
            print(f"==> {script_name} {folder_name}")
            run_step(repo_root, script_name, [folder_name])
    except RuntimeError as exc:
        print(f"Fehler: {exc}")
        sys.exit(1)


if __name__ == "__main__":
    main()

