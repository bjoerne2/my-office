#!/usr/bin/env python3

import sys
import os


def ensure_project_venv():
    """Automatically use the project venv when available."""
    script_dir = os.path.dirname(os.path.abspath(__file__))
    repo_root = script_dir
    venv_python = os.path.join(repo_root, ".venv", "bin", "python")

    if not os.path.isfile(venv_python):
        return

    # Do not compare via realpath: venv Python is often a symlink
    # to the same base interpreter as system Python.
    if os.path.abspath(sys.executable) == os.path.abspath(venv_python):
        return

    os.execv(venv_python, [venv_python, *sys.argv])


def main():
    ensure_project_venv()

    if len(sys.argv) != 2:
        print("Usage: process_paypal_report <report csv file>")
        sys.exit(1)

    input_file = sys.argv[1]

    if not os.path.isfile(input_file):
        print(f"File not found: {input_file}")
        sys.exit(1)

    # Working directory = directory of the input file
    workdir = os.path.dirname(os.path.abspath(input_file))
    os.chdir(workdir)

    filename = os.path.basename(input_file)
    output_file = os.path.splitext(filename)[0] + "_processed.xlsx"

    try:
        import pandas as pd
    except ModuleNotFoundError:
        print("Fehlende Abhängigkeit: pandas")
        print("Bitte im Projektverzeichnis ausführen:")
        print("  python3 -m venv .venv")
        print("  ./.venv/bin/python -m pip install -r requirements.txt")
        sys.exit(1)

    # Load CSV (PayPal often uses ; as separator in DE)
    try:
        df = pd.read_csv(input_file, sep=",", encoding="utf-8")
    except:
        df = pd.read_csv(input_file, sep=";", encoding="utf-8")

    # Remove rows containing "Allgemeine Abbuchung"
    df = df[~df.apply(lambda row: row.astype(str).str.contains("Allgemeine Abbuchung").any(), axis=1)]

    # Remove columns (only when present for robustness)
    columns_to_remove = [
        "Zeitzone",
        "Name",
        "Typ",
        "Status",
        "Währung",
        "Absender E-Mail-Adresse",
        "Empfänger E-Mail-Adresse",
        "Zugehöriger Transaktionscode",
        "Rechnungsnummer",
        "Empfangsnummer"
    ]

    df = df.drop(columns=[col for col in columns_to_remove if col in df.columns])

    # Save Excel output
    df.to_excel(output_file, index=False)

    print(f"✔ Erfolgreich erstellt: {output_file}")


if __name__ == "__main__":
    main()

