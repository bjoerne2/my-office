#!/usr/bin/env python3

from __future__ import annotations

import os
import sys
from collections import Counter, defaultdict
from pathlib import Path


def ensure_project_venv() -> None:
    """Automatically use the project venv when available."""
    script_path = Path(__file__).resolve()
    repo_root = script_path.parent
    venv_python = repo_root / ".venv" / "bin" / "python"

    if not venv_python.is_file():
        return

    if os.path.abspath(sys.executable) == os.path.abspath(venv_python):
        return

    os.execv(str(venv_python), [str(venv_python), *sys.argv])


ensure_project_venv()

from python.args import validate_vendor, validate_year_month
from python.pdf_merge_common import merge_pdfs, resolve_pdf_from_meta
from python.meta import require_meta_entries, require_meta_entry_string, write_meta_entries
from python.vendors import VendorRule, get_vendor_rule


def usage() -> str:
    return "Usage: merge_receipt_and_transaction_pdfs <year> <month> <rechnungssteller>"


def parse_args(argv: list[str]) -> tuple[int, int, VendorRule]:
    if len(argv) != 3:
        raise ValueError(usage())

    year, month = validate_year_month(argv[0], argv[1], example="2026 01")
    vendor = validate_vendor(argv[2], get_vendor_rule)
    return year, month, vendor


def staging_dir(repo_root: Path, year: int, month: int, vendor: VendorRule) -> Path:
    return repo_root / "tmp" / "staging" / f"{year:04d}" / f"{month:02d}" / vendor.directory_name


def merged_output_filenames(billing_filenames: list[str]) -> list[str]:
    output_keys = []
    for billing_filename in billing_filenames:
        suffix = Path(billing_filename).suffix or ".pdf"
        output_stem = f"{Path(billing_filename).stem}-beleg_und_buchung"
        output_keys.append((output_stem, suffix))

    total_counts = Counter(output_keys)
    seen_counts: defaultdict[tuple[str, str], int] = defaultdict(int)
    filenames: list[str] = []

    for output_stem, suffix in output_keys:
        key = (output_stem, suffix)
        seen_counts[key] += 1
        if total_counts[key] == 1:
            filenames.append(f"{output_stem}{suffix}")
        else:
            filenames.append(f"{output_stem}-{seen_counts[key]:03d}{suffix}")

    return filenames

def main() -> None:
    try:
        year, month, vendor = parse_args(sys.argv[1:])
    except ValueError as exc:
        print(exc)
        sys.exit(1)

    repo_root = Path(__file__).resolve().parent
    target_dir = staging_dir(repo_root, year, month, vendor)

    if not target_dir.is_dir():
        print(f"Staging-Ordner nicht gefunden: {target_dir}")
        sys.exit(1)

    try:
        meta_entries = require_meta_entries(target_dir)
        billing_filenames = [
            require_meta_entry_string(entry, "billing_filename", entry_index=index)
            for index, entry in enumerate(meta_entries, start=1)
        ]
        output_filenames = merged_output_filenames(billing_filenames)
        created_paths: list[Path] = []
        updated_entries: list[dict[str, str]] = []

        for index, (entry, output_filename) in enumerate(zip(meta_entries, output_filenames), start=1):
            receipt_pdf = resolve_pdf_from_meta(target_dir, entry, "billing_filename", "Rechnungs-PDF", index)
            transaction_pdf = resolve_pdf_from_meta(target_dir, entry, "transaction_filename", "Kontobeleg-PDF", index)
            output_pdf = target_dir / output_filename
            merge_pdfs(receipt_pdf, transaction_pdf, output_pdf)

            updated_entry = dict(entry)
            updated_entry["merged_filename"] = output_pdf.name
            updated_entries.append(updated_entry)
            created_paths.append(output_pdf)
    except RuntimeError as exc:
        print(f"Fehler: {exc}")
        sys.exit(1)

    write_meta_entries(target_dir, updated_entries)

    for path in created_paths:
        print(path)


if __name__ == "__main__":
    main()
