#!/usr/bin/env python3

from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path


def ensure_project_venv() -> None:
    """Automatically use the project venv when available."""
    script_path = Path(__file__).resolve()
    repo_root = script_path.parent
    venv_python = repo_root / ".venv" / "bin" / "python"

    if not venv_python.is_file():
        return

    if os.path.abspath(sys.executable) == os.path.abspath(venv_python):
        return

    os.execv(str(venv_python), [str(venv_python), *sys.argv])


ensure_project_venv()

from python.args import validate_staging_folder_name, validate_year_month
from python.meta import read_meta_entries
from python.transactions_paths import month_dir


def usage() -> str:
    return "Usage: process_single_receipt <year> <month> <ordnername> [description]"


def parse_args(argv: list[str]) -> tuple[int, int, str, str | None]:
    if len(argv) not in {3, 4}:
        raise ValueError(usage())

    year, month = validate_year_month(argv[0], argv[1], example="2026 01")
    folder_name = validate_staging_folder_name(argv[2])
    description = argv[3].strip() if len(argv) == 4 else None
    if description == "":
        raise ValueError("Beschreibung darf nicht leer sein")
    return year, month, folder_name, description


def run_step(repo_root: Path, script_name: str, args: list[str]) -> None:
    script_path = repo_root / script_name
    if not script_path.is_file():
        raise RuntimeError(f"Skript nicht gefunden: {script_path}")

    command = [str(script_path), *args]
    result = subprocess.run(command, capture_output=True, text=True, check=False)

    if result.stdout:
        print(result.stdout.strip())

    if result.returncode != 0:
        error_output = result.stderr.strip() if result.stderr else ""
        details = error_output or result.stdout.strip() or f"{script_name} fehlgeschlagen"
        raise RuntimeError(details)


def target_dir(repo_root: Path, year: int, month: int, folder_name: str) -> Path:
    return month_dir(repo_root, year, month) / folder_name


def existing_transaction_step(target: Path) -> tuple[str | None, list[str] | None]:
    meta_entries = read_meta_entries(target)
    if len(meta_entries) > 1:
        raise RuntimeError(f"meta.json enthält mehr als einen Eintrag: {target / 'meta.json'}")

    if meta_entries:
        meta_entry = meta_entries[0]
        transaction_filename = meta_entry.get("transaction_filename")
        if isinstance(transaction_filename, str) and transaction_filename.strip():
            transaction_path = target / transaction_filename.strip()
            if transaction_path.is_file():
                payment_method = meta_entry.get("payment_method")
                cash_amount = meta_entry.get("cash_amount")
                if payment_method == "cash" and isinstance(cash_amount, str) and cash_amount.strip():
                    return "create_cash_payment_pdf", [cash_amount.strip()]
                return "skip", None

    return None, None


def main() -> None:
    try:
        year, month, folder_name, description = parse_args(sys.argv[1:])
    except ValueError as exc:
        print(exc)
        sys.exit(1)

    repo_root = Path(__file__).resolve().parent
    target = target_dir(repo_root, year, month, folder_name)

    try:
        detect_args = [f"{year:04d}", f"{month:02d}", folder_name]
        if description is not None:
            detect_args.append(description)
        print(f"==> detect_single_receipt_pdf {' '.join(detect_args)}")
        run_step(repo_root, "detect_single_receipt_pdf", detect_args)

        create_args = [f"{year:04d}", f"{month:02d}", folder_name]
        existing_step, extra_args = existing_transaction_step(target)
        if existing_step == "skip":
            print("==> create_single_transaction_pdf übersprungen (vorhandenes Transaktions-PDF)")
        elif existing_step == "create_cash_payment_pdf":
            cash_args = [*create_args, *(extra_args or [])]
            print(f"==> create_cash_payment_pdf {' '.join(cash_args)}")
            run_step(repo_root, "create_cash_payment_pdf", cash_args)
        else:
            print(f"==> create_single_transaction_pdf {' '.join(create_args)}")
            run_step(repo_root, "create_single_transaction_pdf", create_args)

        print(f"==> merge_single_receipt_and_transaction_pdf {' '.join(create_args)}")
        run_step(repo_root, "merge_single_receipt_and_transaction_pdf", create_args)
    except RuntimeError as exc:
        print(f"Fehler: {exc}")
        sys.exit(1)


if __name__ == "__main__":
    main()
