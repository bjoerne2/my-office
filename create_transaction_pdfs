#!/usr/bin/env python3

from __future__ import annotations

import csv
import os
import re
import sys
from pathlib import Path


def ensure_project_venv() -> None:
    """Automatically use the project venv when available."""
    script_path = Path(__file__).resolve()
    repo_root = script_path.parent
    venv_python = repo_root / ".venv" / "bin" / "python"

    if not venv_python.is_file():
        return

    if os.path.abspath(sys.executable) == os.path.abspath(venv_python):
        return

    os.execv(str(venv_python), [str(venv_python), *sys.argv])


ensure_project_venv()

from reportlab.lib import colors
from reportlab.lib.pagesizes import A4
from reportlab.lib.styles import getSampleStyleSheet
from reportlab.lib.units import mm
from reportlab.platypus import Paragraph, SimpleDocTemplate, Spacer, Table, TableStyle

from python.args import validate_vendor, validate_year_month
from python.meta import read_meta_entries, write_meta_entries
from python.vendors import VendorRule, get_vendor_rule


PURPOSE_FIELD_LABELS = {
    "Umsatzart": "Umsatzart",
    "Referenz": "Referenznummer",
    "Mandat": "Mandatsnummer",
    "Gläubiger-ID": "Gläubiger-ID",
}

PURPOSE_FIELD_PATTERN = re.compile(r",\s*(Umsatzart|Referenz|Mandat|Gläubiger-ID):\s*")
DATE_FIELD_LABELS = ("Datum", "Buchungstag")
ACCOUNT_NAME_FIELD_LABELS = ("Kontobezeichnung",)


def usage() -> str:
    return "Usage: create_transaction_pdfs <year> <month> <rechnungssteller>"


def parse_args(argv: list[str]) -> tuple[int, int, VendorRule]:
    if len(argv) != 3:
        raise ValueError(usage())

    year, month = validate_year_month(argv[0], argv[1], example="2026 01")
    vendor = validate_vendor(argv[2], get_vendor_rule)
    return year, month, vendor


def transactions_csv_path(repo_root: Path, year: int, month: int, vendor: VendorRule) -> Path:
    return repo_root / "tmp" / "staging" / f"{year:04d}" / f"{month:02d}" / vendor.directory_name / "transactions.csv"


def output_dir(repo_root: Path, year: int, month: int, vendor: VendorRule) -> Path:
    return repo_root / "tmp" / "staging" / f"{year:04d}" / f"{month:02d}" / vendor.directory_name


def read_transactions(csv_path: Path) -> tuple[list[str], list[list[str]]]:
    with csv_path.open("r", encoding="utf-8-sig", newline="") as handle:
        reader = csv.reader(handle, delimiter=";")

        try:
            header = next(reader)
        except StopIteration as exc:
            raise RuntimeError(f"Leere CSV-Datei: {csv_path}") from exc

        rows = [row for row in reader if row and any(cell.strip() for cell in row)]

    if not rows:
        raise RuntimeError(f"Keine Transaktionen in {csv_path} gefunden")

    return header, rows


def find_first_column_value(header: list[str], row: list[str], supported_labels: tuple[str, ...]) -> str:
    for label in supported_labels:
        if label in header:
            column_index = header.index(label)
            if column_index < len(row):
                return row[column_index].strip()

    return row[0].strip() if row else ""


def find_optional_column_value(header: list[str], row: list[str], supported_labels: tuple[str, ...]) -> str | None:
    for label in supported_labels:
        if label in header:
            column_index = header.index(label)
            if column_index < len(row):
                value = row[column_index].strip()
                return value or None

    return None


def transaction_pdf_path(header: list[str], target_dir: Path, row: list[str], index: int) -> Path:
    booking_date = find_first_column_value(header, row, DATE_FIELD_LABELS)
    booking_date_slug = booking_date.replace(".", "-") if booking_date else f"row-{index:03d}"
    filename = f"transaction-{booking_date_slug}-{index:03d}.pdf"
    return target_dir / filename


def parse_purpose_details(purpose: str) -> tuple[str, dict[str, str]]:
    normalized_purpose = purpose.strip()
    matches = list(PURPOSE_FIELD_PATTERN.finditer(normalized_purpose))

    if not matches:
        return normalized_purpose, {}

    description = normalized_purpose[: matches[0].start()].strip(" ,")
    parsed_fields: dict[str, str] = {}

    for index, match in enumerate(matches):
        source_label = match.group(1)
        value_start = match.end()
        value_end = matches[index + 1].start() if index + 1 < len(matches) else len(normalized_purpose)
        value = normalized_purpose[value_start:value_end].strip(" ,")
        target_label = PURPOSE_FIELD_LABELS[source_label]
        parsed_fields[target_label] = value

    return description, parsed_fields


def build_table_data(header: list[str], row: list[str], account_name: str | None = None) -> list[list[str]]:
    pairs: list[list[str]] = []
    if account_name:
        pairs.append(["Konto", account_name])

    for key, value in zip(header, row):
        if key in ACCOUNT_NAME_FIELD_LABELS:
            continue
        if key == "Verwendungszweck":
            description, parsed_fields = parse_purpose_details(value or "")

            if description and description != (value or ""):
                pairs.append(["Verwendungszweck", description])

            for label in ("Umsatzart", "Referenznummer", "Mandatsnummer", "Gläubiger-ID"):
                if label in parsed_fields:
                    pairs.append([label, parsed_fields[label]])
        else:
            pairs.append([key, value or ""])

    return pairs


def read_billing_filename(meta_entry: dict[str, str]) -> str | None:
    billing_filename = meta_entry.get("billing_filename")
    if isinstance(billing_filename, str) and billing_filename.strip():
        return billing_filename.strip()

    return None


def read_account_name(meta_entry: dict[str, str]) -> str | None:
    account_name = meta_entry.get("account_name")
    if isinstance(account_name, str) and account_name.strip():
        return account_name.strip()

    return None


def load_meta_entries(target_dir: Path, expected_count: int) -> list[dict[str, str]]:
    entries = read_meta_entries(target_dir)
    if not entries:
        return [{} for _ in range(expected_count)]

    if len(entries) != expected_count:
        raise RuntimeError(
            f"meta.json enthält {len(entries)} Einträge, erwartet werden {expected_count}. "
            "Bitte match_receipts erneut ausführen."
        )

    return [dict(entry) for entry in entries]


def make_table(table_data: list[list[str]]) -> Table:
    table = Table(table_data, colWidths=[55 * mm, 115 * mm])
    table.setStyle(
        TableStyle(
            [
                ("BACKGROUND", (0, 0), (0, -1), colors.HexColor("#f0f0f0")),
                ("BOX", (0, 0), (-1, -1), 0.5, colors.black),
                ("INNERGRID", (0, 0), (-1, -1), 0.25, colors.grey),
                ("VALIGN", (0, 0), (-1, -1), "TOP"),
                ("FONTNAME", (0, 0), (0, -1), "Helvetica-Bold"),
                ("FONTNAME", (1, 0), (1, -1), "Helvetica"),
                ("FONTSIZE", (0, 0), (-1, -1), 10),
                ("LEADING", (0, 0), (-1, -1), 12),
                ("LEFTPADDING", (0, 0), (-1, -1), 6),
                ("RIGHTPADDING", (0, 0), (-1, -1), 6),
                ("TOPPADDING", (0, 0), (-1, -1), 6),
                ("BOTTOMPADDING", (0, 0), (-1, -1), 6),
            ]
        )
    )
    return table


def write_transaction_pdf(
    output_path: Path,
    vendor: VendorRule,
    header: list[str],
    row: list[str],
    index: int,
    billing_filename: str | None,
    account_name: str | None,
) -> None:
    output_path.parent.mkdir(parents=True, exist_ok=True)

    styles = getSampleStyleSheet()
    story = [
        Paragraph("Buchung", styles["Title"]),
        Spacer(1, 8 * mm),
    ]

    summary_rows: list[list[str]] = []
    if billing_filename:
        summary_rows.append(["Rechnung", billing_filename])

    if summary_rows:
        story.append(make_table(summary_rows))
        story.append(Spacer(1, 6 * mm))

    story.append(make_table(build_table_data(header, row, account_name)))

    document = SimpleDocTemplate(
        str(output_path),
        pagesize=A4,
        leftMargin=15 * mm,
        rightMargin=15 * mm,
        topMargin=15 * mm,
        bottomMargin=15 * mm,
        title="Buchung",
    )
    document.build(story)


def main() -> None:

    try:
        year, month, vendor = parse_args(sys.argv[1:])
    except ValueError as exc:
        print(exc)
        sys.exit(1)

    repo_root = Path(__file__).resolve().parent
    csv_path = transactions_csv_path(repo_root, year, month, vendor)
    target_dir = output_dir(repo_root, year, month, vendor)

    if not csv_path.is_file():
        print(f"Transaktionsdatei nicht gefunden: {csv_path}")
        sys.exit(1)

    try:
        header, rows = read_transactions(csv_path)
    except RuntimeError as exc:
        print(f"Fehler: {exc}")
        sys.exit(1)

    try:
        meta_entries = load_meta_entries(target_dir, len(rows))
    except RuntimeError as exc:
        print(f"Fehler: {exc}")
        sys.exit(1)

    created_paths: list[Path] = []
    for index, row in enumerate(rows, start=1):
        meta_entry = meta_entries[index - 1]
        billing_filename = read_billing_filename(meta_entry)
        account_name = find_optional_column_value(header, row, ACCOUNT_NAME_FIELD_LABELS) or read_account_name(meta_entry)
        pdf_path = transaction_pdf_path(header, target_dir, row, index)
        write_transaction_pdf(pdf_path, vendor, header, row, index, billing_filename, account_name)
        created_paths.append(pdf_path)
        meta_entry["transaction_filename"] = pdf_path.name
        if account_name:
            meta_entry["account_name"] = account_name

    if created_paths:
        write_meta_entries(target_dir, meta_entries)

    for path in created_paths:
        print(path)


if __name__ == "__main__":
    main()
