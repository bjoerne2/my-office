#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Synchronisiert tmp/app_scripts_data unidirektional von einem Google-Drive-Ordner nach lokal via rclone sync.

Verwendung:
  sync_app_scripts_data [<remote:path>] [weitere-rclone-optionen]

Beispiele:
  ./rclone/sync_app_scripts_data gdrive:app_scripts_data
  RCLONE_REMOTE_PATH="gdrive:app_scripts_data" ./rclone/sync_app_scripts_data
  RCLONE_REMOTE_PATH="gdrive:app_scripts_data" ./rclone/sync_app_scripts_data --dry-run

Hinweise:
- Wenn kein <remote:path> uebergeben wird, wird RCLONE_REMOTE_PATH verwendet.
- Lokale Dateien, die remote nicht existieren, werden durch "rclone sync" geloescht.
- Weitere Optionen werden direkt an "rclone sync" durchgereicht.
EOF
}

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
LOCAL_DIR="$REPO_ROOT/tmp/app_scripts_data"
LOG_DIR="$SCRIPT_DIR/logs"

remote_path="${RCLONE_REMOTE_PATH:-}"
extra_args=()

while (($# > 0)); do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      extra_args+=("$@")
      break
      ;;
    -* )
      extra_args+=("$1")
      shift
      ;;
    *)
      if [[ -z "$remote_path" ]]; then
        remote_path="$1"
      else
        extra_args+=("$1")
      fi
      shift
      ;;
  esac
done

if ! command -v rclone >/dev/null 2>&1; then
  echo "Fehler: rclone ist nicht installiert oder nicht im PATH verfuegbar." >&2
  echo "Siehe /Users/bjoerne/Source/my-office/README.md fuer die Installation." >&2
  exit 1
fi

if [[ -z "$remote_path" ]]; then
  echo "Fehler: Bitte einen rclone-Remote-Pfad angeben, z.B. gdrive:app_scripts_data" >&2
  echo >&2
  usage >&2
  exit 1
fi

mkdir -p "$LOCAL_DIR" "$LOG_DIR"

log_file="$LOG_DIR/sync_app_scripts_data_$(date +%Y%m%d_%H%M%S).log"

echo "Starte unidirektionalen Sync (remote -> lokal)"
echo "  Lokal : $LOCAL_DIR"
echo "  Remote: $remote_path"
echo "  Log   : $log_file"

cmd=(
  rclone sync "$remote_path" "$LOCAL_DIR"
  --create-empty-src-dirs
  --log-file "$log_file"
  --log-level INFO
)

if ((${#extra_args[@]} > 0)); then
  cmd+=("${extra_args[@]}")
fi

if ! "${cmd[@]}"; then
  echo "Sync fehlgeschlagen. Details siehe $log_file" >&2
  exit 1
fi

echo "Fertig. Details siehe $log_file"



