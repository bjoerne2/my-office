#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Synchronisiert tmp/app_scripts_data bidirektional mit einem Google-Drive-Ordner via rclone bisync.

Verwendung:
  sync_app_scripts_data [<remote:path>] [--resync] [weitere-rclone-optionen]

Beispiele:
  ./rclone/sync_app_scripts_data gdrive:app_scripts_data --resync
  RCLONE_REMOTE_PATH="gdrive:app_scripts_data" ./rclone/sync_app_scripts_data
  RCLONE_REMOTE_PATH="gdrive:app_scripts_data" ./rclone/sync_app_scripts_data --dry-run

Hinweise:
- Beim allerersten Lauf ist in der Regel --resync sinnvoll.
- Wenn kein <remote:path> uebergeben wird, wird RCLONE_REMOTE_PATH verwendet.
- Weitere Optionen werden direkt an "rclone bisync" durchgereicht.
EOF
}

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
LOCAL_DIR="$REPO_ROOT/tmp/app_scripts_data"
WORK_DIR="$SCRIPT_DIR/.bisync"
LOG_DIR="$SCRIPT_DIR/logs"

remote_path="${RCLONE_REMOTE_PATH:-}"
extra_args=()

while (($# > 0)); do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      extra_args+=("$@")
      break
      ;;
    -* )
      extra_args+=("$1")
      shift
      ;;
    *)
      if [[ -z "$remote_path" ]]; then
        remote_path="$1"
      else
        extra_args+=("$1")
      fi
      shift
      ;;
  esac
done

if ! command -v rclone >/dev/null 2>&1; then
  echo "Fehler: rclone ist nicht installiert oder nicht im PATH verfuegbar." >&2
  echo "Siehe /Users/bjoerne/Source/my-office/rclone/README.md fuer die Installation." >&2
  exit 1
fi

if [[ -z "$remote_path" ]]; then
  echo "Fehler: Bitte einen rclone-Remote-Pfad angeben, z.B. gdrive:app_scripts_data" >&2
  echo >&2
  usage >&2
  exit 1
fi

mkdir -p "$LOCAL_DIR" "$WORK_DIR" "$LOG_DIR"

log_file="$LOG_DIR/sync_app_scripts_data_$(date +%Y%m%d_%H%M%S).log"

echo "Starte bidirektionalen Sync"
echo "  Lokal : $LOCAL_DIR"
echo "  Remote: $remote_path"
echo "  Log   : $log_file"

rclone bisync "$LOCAL_DIR" "$remote_path" \
  --check-access \
  --create-empty-src-dirs \
  --compare size,modtime \
  --workdir "$WORK_DIR" \
  --log-file "$log_file" \
  --log-level INFO \
  "${extra_args[@]}"

echo "Fertig. Details siehe $log_file"



